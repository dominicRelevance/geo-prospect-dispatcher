# Local testing: copy to .env and fill in (or export these directly).
# On Railway: set these as real environment variables on the dispatcher
# service (dashboard → Variables), not as a committed file.

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
SPREADSHEET_ID=1co2Y-o4RoiMs4Y-ElRH_hatUTJPvNHcWCIChMILYwCA
SHEET_NAME=Jobs

# --- Mailjet SMTP ---
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=reports@relevance.digital
MAILJET_FROM_NAME=Relevance Digital

# --- Railway CLI (targets Alex's geo-prospect worker) ---
RAILWAY_SERVICE=geo-prospect
# RAILWAY_TOKEN — project-scoped token, only needed when this dispatcher
# itself runs as a deployed Railway service (not from a machine that's
# already done `railway login` + `railway link` interactively).
RAILWAY_TOKEN=

# --- Timeouts (seconds) ---
DISCOVERY_TIMEOUT_S=600
AUDIT_TIMEOUT_S=2700

# --- Reports hosting (reports_server/, a separate always-on Railway
# service — see its own README section in NOTES.md) ---
REPORTS_HOST_URL=https://geo-prospect-reports-production.up.railway.app
REPORTS_UPLOAD_TOKEN=
